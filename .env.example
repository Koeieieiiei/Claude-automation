# ============================================================
#  ตัวอย่างไฟล์ environment variables
#  วิธีใช้: ก๊อปปี้ไฟล์นี้เป็นชื่อ .env.local แล้วใส่ค่าจริงของคุณ
#  (ไฟล์ .env.local จะไม่ถูก commit ขึ้น git เพราะอยู่ใน .gitignore)
#
#  ⚠️ ตอนเริ่มต้นยังไม่มีค่าจริงก็ได้ ระบบจะรันในโหมด "ทดสอบ (mock)"
#     โดยข้ามการเรียก service ภายนอก เพื่อให้คุณเห็นหน้าเว็บก่อน
# ============================================================

# ---------- ข้อมูลร้าน ----------
# ⚠️ ชื่อและราคาสินค้าทุกตัว (Mock / สรุป / bundle) แก้ที่ไฟล์ lib/catalog.ts ที่เดียว
# ชื่อเว็บ (โชว์บน title และอีเมล)
NEXT_PUBLIC_SITE_NAME="Tpat3 and Physics by Mrtpat3"
# URL ของเว็บ (ตอน deploy แล้วใส่โดเมนจริง เช่น https://yourshop.vercel.app)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---------- Stripe (รับชำระเงิน: บัตร + PromptPay) ----------
# 👤 เอาจาก https://dashboard.stripe.com/apikeys
#    ตอนทดสอบใช้คีย์ที่ขึ้นต้น sk_test_ ; ตอนใช้จริงเปลี่ยนเป็น sk_live_
STRIPE_SECRET_KEY=
# Webhook signing secret (ขึ้นต้น whsec_) เอาจาก Stripe > Developers > Webhooks
# ตอนทดสอบ local ใช้คำสั่ง: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# สกุลเงิน (thb = บาท)
STRIPE_CURRENCY=thb

# ---------- Supabase (ฐานข้อมูล + เก็บไฟล์) ----------
# 👤 เอาจาก Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# ชื่อ storage bucket สำหรับเก็บ PDF (สร้างใน Supabase > Storage)
SUPABASE_BUCKET=ebooks

# ---------- Resend (ส่งอีเมลไฟล์ให้ลูกค้า) ----------
# 👤 เอาจาก https://resend.com > API Keys
RESEND_API_KEY=
# อีเมลผู้ส่ง (ต้อง verify โดเมนใน Resend ก่อน หรือใช้ onboarding@resend.dev ตอนทดสอบ)
EMAIL_FROM="ร้านข้อสอบ <onboarding@resend.dev>"

# ---------- Google Sheets (เก็บสถิติ) ----------
# 👤 เปิด Google Sheets API + สร้าง Service Account แล้วเอา client_email กับ private_key มา
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# private_key ให้ใส่ทั้งก้อนในเครื่องหมายคำพูด และคง \n ไว้ (ห้ามเว้นบรรทัดจริง)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ---------- ความปลอดภัย ----------
# คีย์ลับสุ่มยาวๆ ใช้เซ็นลิงก์ดาวน์โหลด (สร้างเองด้วย: openssl rand -hex 32)
DOWNLOAD_SECRET=change-me-to-a-long-random-string
# ลิงก์ดาวน์โหลดหมดอายุในกี่ชั่วโมง (168 = 7 วัน)
DOWNLOAD_EXPIRY_HOURS=168
